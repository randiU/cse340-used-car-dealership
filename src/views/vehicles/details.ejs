<%- include("../partials/header") %>

<h1><%= title %></h1>

<main>
    <article>
        <p><strong>Category:</strong> <%= vehicle.category_name %></p>
        <p><strong>Price:</strong> $<%= Number(vehicle.price).toLocaleString() %></p>
